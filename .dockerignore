.git
.gitignore
.DS_Store

# Build outputs never belong in the build context.
build/
out/
dist/

# Local data
var/
backup/
etc/
*.db

# Python leftovers (the server is Go now; these must never enter the context)
server/.venv/
**/__pycache__/
**/*.egg-info/
.pytest_cache/

# Stray artifacts from the old build system
*.dmg
*.exe
*.deb
*.rpm
task-timer-linux-arm64
task-timer-windows-amd64.exe
TaskTimer.dmg
